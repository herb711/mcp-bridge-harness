{
  "name": "mcp-harness",
  "version": "0.2.5",
  "description": "A local MCP manager and marketplace harness for OpenCode, Codex, Claude Code and bundled MiniMax MCP tools.",
  "type": "module",
  "author": "MCP Harness",
  "license": "Apache-2.0",
  "homepage": "https://github.com/herb711/mcp-bridge-harness",
  "bin": {
    "mcp-harness": "./dist/index.js",
    "minimax-bridge-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "npm run app:dev",
    "dev:mcp": "tsx src/index.ts mcp minimax-bridge",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js app",
    "harness": "node dist/index.js app",
    "harness:install": "node dist/index.js install",
    "harness:install:open": "node dist/index.js install --open",
    "mcp:minimax": "node dist/index.js mcp minimax-bridge",
    "manifest": "node dist/index.js --manifest",
    "tools": "node dist/index.js --tools",
    "configure": "node scripts/configure.mjs --write-files --copy --print",
    "install:opencode": "node dist/index.js app",
    "app:dev": "npm run build && electron desktop/main.cjs",
    "app": "node dist/index.js app",
    "desktop": "node dist/index.js app",
    "serve": "node dist/index.js serve",
    "web": "node dist/index.js serve",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --x64 --publish never",
    "dist:current": "npm run build && electron-builder --publish never",
    "release:desktop": "npm run build && node scripts/generate-agent-manifest.mjs && electron-builder --publish never",
    "release:win": "npm run build && node scripts/generate-agent-manifest.mjs && electron-builder --win --x64 --publish never",
    "prepare:desktop": "npm run release:win",
    "test": "npm run test:codex",
    "test:codex": "npm run build && node --test test/*.test.mjs"
  },
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.12",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist",
    "web",
    "desktop",
    "scripts",
    "install.bat",
    "install.sh",
    "examples",
    "docs",
    "agent.manifest.json",
    "README.md",
    "README.zh.md",
    "LICENSE",
    "NOTICE"
  ],
  "build": {
    "appId": "com.mcpharness.desktop",
    "productName": "MCP Harness",
    "copyright": "Copyright © 2026 MCP Harness",
    "directories": {
      "output": "release/desktop",
      "buildResources": "."
    },
    "files": [
      "dist/**",
      "web/**",
      "desktop/**",
      "node_modules/**",
      "package.json",
      "agent.manifest.json"
    ],
    "asar": true,
    "asarUnpack": [],
    "icon": "logo.png",
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MCP Harness",
      "deleteAppDataOnUninstall": false,
      "artifactName": "mcp-harness-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "mcp-harness-${version}-${arch}-portable.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "logo.png",
      "artifactName": "mcp-harness-${version}-${arch}-dmg.${ext}"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Development",
      "icon": "logo.png",
      "artifactName": "mcp-harness-${version}-${arch}-appimage.${ext}"
    }
  }
}
