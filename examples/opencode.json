{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "minimax-bridge": {
      "type": "local",
      "command": [
        "node",
        "/absolute/path/to/mcp-harness/dist/index.js",
        "mcp",
        "minimax-bridge",
        "--profile",
        "default"
      ],
      "enabled": true,
      "timeout": 15000,
      "environment": {
        "MCP_HARNESS_HOME": "/absolute/path/to/McpHarness"
      }
    }
  }
}
